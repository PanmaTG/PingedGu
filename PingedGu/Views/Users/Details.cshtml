@model GetUserProfileViewModel;

<main id="site__main" class="2xl:ml-[--w-side] xl:ml-[--w-side-sm] p-2.5 h-[calc(100vh-var(--m-top))] mt-[--m-top]">
    
    <div class="max-w-[1065px] mx-auto max-lg:-m-2.5">

        @* TOP PROFILE DETAILS SECTION *@
        <div class="bg-white shadow lg:rounded-b-xl lg:-mt-10">
            <div class="relative overflow-hidden w-full lg:h-8 h-8"></div>
            <div class="p-3 flex flex-row items-center">

                <div class="flex-shrink-0 mr-4">
                    <div class="relative h-28 w-28">
                        <div class="relative overflow-hidden rounded-full md:border-[6px] border-gray-100 shrink-0 h-full w-full">
                            <img src="@(string.IsNullOrEmpty(Model.User.PfpUrl)  
                                ? Url.Content("~/images/avatar/user.png") 
                                : Url.Content("~/" + Model.User.PfpUrl))" />
                        </div>
                    </div> 
                </div>

                <div>
                    <h3 class="md:text-3xl ml-4 text-base font-bold text-black">@Model.User.FullName</h3>
                    <p class="mt-2 ml-4 text-gray-500">@Model.User.UserName</p>
                </div>
            </div>
        </div>

        @* BOTTOM PROFILE DETAILS SECTION - user posts, etc. *@
        <div class="flex 2xl:gap-12 gap-10 mt-8 max-lg:flex-col" id="js-oversized">
            @* OWN USER POSTS SECTION *@
            <div class="flex-1 xl\:space-y-6 space-y-3">
                @foreach(var post in Model.Posts)
                {
                    <partial name="Timeline/_Post" model="post" 
                        view-data='new ViewDataDictionary(ViewData) 
                        { 
                            { "ShowAllComment", false },
                            { "ShowDetails", false    } 
                        }'/>
                }
            </div>

            @* FOLLOWERS SECTION *@
            <div class="lg:w-[400px]">
                <div class="lg:space-y-4 lg:pb-8 max-lg:grid sm:grid-cols-2 max-lg:gap-6"
                     uk-sticky="media: 1024; end: #js-oversized; offset: 80">

                    <div class="box p-5 px-6">

                        <div class="flex items-center justify-between !text-black">
                            <h3>
                                Followers
                                <span class="block text-sm text-gray-500 mt-0. font-normal">
                                    @(Model.Friends.Count == 0 ? "No followers"
                                      : Model.Friends.Count == 1 ? "1 follower"
                                      : $"{Model.Friends.Count} followers")
                                </span>
                            </h3>
                        </div>

                        <div class="grid grid-cols-3 gap-2 gap-y-5 text-center text-sm mt-4 mb-2">
                            @foreach (var friend in Model.Friends)
                            {
                                <a asp-controller="Users" asp-action="Details" asp-route-userId="@friend.User.Id">
                                    <div class="relative w-full aspect-square rounded-lg overflow-hidden">
                                        <img src="@(string.IsNullOrEmpty(friend.User.PfpUrl)
                                                                             ? Url.Content("~/images/avatar/user.png")
                                                                             : Url.Content("~/" + friend.User.PfpUrl))"
                                             class="object-cover w-full h-full inset-0" />
                                    </div>

                                    <div class="mt-2 line-clamp-1">
                                        @friend.User.FullName
                                    </div>
                                </a>
                            }
                        </div>
                    </div>

                </div>
            </div>
        </div>


    </div>

</main>