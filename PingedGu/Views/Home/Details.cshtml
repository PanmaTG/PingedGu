@model Post

@if (Model == null)
{
    <div class="p-8 text-center text-gray-500">Post not found.</div>
}
else
{
    <main id="site__main" class="2xl:ml-[--w-side] xl:ml-[--w-side-sm] p-2.5 h-[calc(100vh-var(--m-top))] mt-[--m-top]">
        <div class="w-full h-full" id="js-oversized">
            <div class="w-full h-full">
                <partial name="Timeline/_Post" model="Model" view-data='new ViewDataDictionary(ViewData)
                       { { "ShowAllComment", true } }' />
            </div>
        </div>
    </main>
}
