@using System.Security.Claims;
@model Post

@{
    TimeSpan timeSpanSincePosted = DateTime.UtcNow.Subtract(Model.DateCreated);

    // string displayTime = "";

    // if(timeSpanSincePosted.TotalDays >= 1)
    // {
    //     displayTime = $"{timeSpanSincePosted.Days} days ago";
    // }
    // else if (timeSpanSincePosted.TotalHours >= 1) {
    //     displayTime = $"{timeSpanSincePosted.Hours} hours ago";
    // }
    // else if (timeSpanSincePosted.TotalMinutes >= 1)
    // {
    //     displayTime = $"{timeSpanSincePosted.Minutes} minutes ago";
    // } else
    // {
    //     displayTime = "Just now";
    // }

    int loggedInUserId = int.TryParse(User.FindFirstValue(ClaimTypes.NameIdentifier), out int result) ? result : 0;

    string displayTime = timeSpanSincePosted switch
    {
        var t when t.TotalDays > 730 => $"{(int)t.Days / 365} years ago",
        var t when t.TotalDays == 365 => $"a year ago",
        var t when t.TotalDays >= 60 => $"{(int)t.Days / 30} months ago",
        var t when t.TotalDays >= 30 => $"a month ago",
        var t when t.TotalDays >= 2 => $"{(int)t.Days} days ago",
        var t when t.TotalDays >= 1 => $"a day ago",
        var t when t.TotalHours > 1 => $"{(int)t.Hours} hours ago",
        var t when t.TotalHours == 1 => $"an hour ago",
        var t when t.TotalMinutes > 1 => $"{(int)t.Minutes} minutes ago",
        var t when t.TotalMinutes == 1 => $"a minute ago",
        _ => "Just now"
    };

    bool isLiked = Model.Likes.Any(n => n.UserId == loggedInUserId);
    bool isFavorited = Model.Favorites.Any(n => n.UserId == loggedInUserId);
    bool isPrivate = Model.IsPrivate == true && Model.UserId == loggedInUserId;
    bool isReported = Model.Reports.Any(n => n.UserId == loggedInUserId);

    string defaultUserPfp = "~/images/avatar/user.png";
    string currentUserPfp = ViewData["CurrentUserPfp"] as string ?? defaultUserPfp;

    bool showAllComments = ViewData["ShowAllComment"] as bool? ?? false;
    bool showDetails = ViewData["ShowDetails"] as bool? ?? true;
}

<div id="post-@Model.Id" class="bg-white rounded-xl shadow-sm text-sm font-medium \!border-0">

    @* USER POST HEADING *@
    <div class="flex gap-3 sm:p-4 p-2.5 text-sm font-medium">

        @* USER PROFILE PICTURE *@
        <a asp-controller="Users" asp-action="Details" asp-route-userId="@Model.UserId">
            @* 2 '?' *@
            <img src="@(!string.IsNullOrEmpty(Model.User.PfpUrl)
                                 ? Url.Content("~/" + Model.User.PfpUrl)
                                 : Url.Content(defaultUserPfp))" class="w-9 h-9 rounded-full" />

            @* 1 '?' *@
            @* or <img src="@(string.IsNullOrEmpty(post.User.PfpUrl) ? "~/images/profilepic/temp-pfp.jpg" : post.User.PfpUrl) class="w-9 h-9 rounded-full" /> *@
        </a>

        @* NAME & DATE OF POSTING *@
        <div class="flex-1">
            <a asp-controller="Users" asp-action="Details" asp-route-userId="@Model.UserId">
                <h4 class="!text-black">@Model.User.FullName</h4>
                <div class="text-xs text-gray-500" title="@Model.DateCreated.ToString("MMM. dd, yyyy HH:mmtt")">@displayTime</div>
            </a>
        </div>

        @* MORE OPTIONS POSTS BUTTON *@
        <div class="-mr-1">
            <button type="button" class="button-icon w-8 h-8 text-gray-500">
                <ion-icon class="text-xl" name="ellipsis-horizontal"></ion-icon>
            </button>

            <div class="w-\[245px\] post-options-dropdown" uk-dropdown="pos: bottom-right;
                animation: uk-animation-scale-up uk-transform-origin-top-right;
                animate-out: true; mode: click" style="background-color: #fff">

                @if (Model.UserId == loggedInUserId)
                {
                    @* SET AS PRIVATE BUTTON *@
                    <form asp-controller="Home" asp-action="TogglePostVisibility" class="toggle-post-visibility-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="postId" value="@Model.Id" />
                        <button type="submit" class="hover:!bg-red-50 icon-link text-gray-900">
                            <ion-icon name="@(isPrivate ? "lock-open-outline" : "lock-closed-outline")" class="text-xl"></ion-icon> Set As @(isPrivate ? "Public" : "Private")
                        </button>
                    </form>
                    <hr />

                    @* DELETE POST BUTTON *@
                    <form asp-controller="Home" asp-action="PostRemove" class="remove-post-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="postId" value="@Model.Id" />
                        <button type="submit" class="text-red-400 hover:!bg-red-50 delete-post-btn text-gray-900">
                            <ion-icon class="text-xl" name="trash-bin-outline"></ion-icon> Delete
                        </button>
                    </form>

                }

                @* REPORT BUTTON *@
                @if (!isReported)
                {
                    <form asp-controller="Home" asp-action="AddPostReport" class="add-post-report-form">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="postId" value="@Model.Id" />
                        <button type="submit" class="hover:!bg-red-50 icon-link text-gray-900">
                            <ion-icon class="text-xl shrink-0" name="flag-outline"></ion-icon> Report
                        </button>
                    </form>
                }

            </div>
        </div>
    </div>

    @* USER POST CONTENT *@
    @* POST DESCRIPTION *@
    <a asp-controller="Home" asp-action="Details" asp-route-postId="@Model.Id">
        <div class="px-sm-4 p-2.5 pt-0 w-full">
            <p class="font-normal text-black">
                @Model.Content
            </p>
        </div>
    </a>

    @* POST IMAGE *@
    @if (!string.IsNullOrEmpty(Model.ImageUrl))
    {
        <a asp-controller="Home" asp-action="Details" asp-route-postId="@Model.Id">
            <div class="relative w-full h-full">
                <img src="@Url.Content("~/" + Model.ImageUrl)" class="sm:rounded-lg w-full h-full object-cover" />
            </div>
        </a>
    }


    @* ICONS *@
    @* USER POST LIKES, REPLIES, AND BOOKMARKS ICONS *@
    <div class="sm:p-4 p-2.5 flex items-center gap-4 text-xs font-semibold">

        @* LIKES COUNT *@
        <div class="flex items-center gap-2.5" style="color: rgb(75, 85, 99)">
            <form asp-controller="Home" asp-action="TogglePostLike">
                @Html.AntiForgeryToken()
                <input type="hidden" name="postId" value="@Model.Id" />
                <button type="submit" class="button-icon like-button @(isLiked ? "text-red-500 bg-red-100" : "")">
                    <ion-icon name="@(isLiked ? "heart" : "heart-outline")" class="text-lg"></ion-icon>
                </button>
            </form>

            <a href="">@Model.Likes.Count</a>
        </div>

        @* COMMENTS/REPLIES COUNT *@
        <div class="flex items-center gap-3" style="color: rgb(75, 85, 99)">
            <a class="button-icon">
                <ion-icon name="chatbubble-ellipses-outline" class="text-lg"></ion-icon>
            </a>
            <a href="">@Model.Comments.Count</a>
        </div>

        <div class="ml-auto"></div>

        @* FAVORITES/BOOKMARKS *@
        <div class="flex items-center gap-2">
            @if (Model.Favorites.Count > 0)
            {
                <a href="#" class="text-gray-500">@Model.Favorites.Count</a>
            }
            <form asp-controller="Home" asp-action="TogglePostFavorite">
                <input type="hidden" name="postId" value="@Model.Id" />
                <button type="submit" class="button-icon ml-auto favorite-button @(isFavorited ? "text-blue-500 bt-blue-100" : "text-gray-600")">
                    <ion-icon name="@(isFavorited ? "bookmark" : "bookmark-outline")" class="text-lg"></ion-icon>
                </button>

                @*   <button type="submit" class="button-icon ml-auto">
                    <ion-icon name="@(isFavorited ? "bookmark" : "bookmark-outline")"
                              class="text-lg"
                              style="color: @(isFavorited ? "#3b82f6" : "#6b7280")">
                    </ion-icon>
                </button> *@

            </form>

        </div>
    </div>

    @if (showDetails)
    {
        @* USER COMMENTS/REPLIES UNDER USER POSTS *@
        <div>

            <div class="p-2.5 border-t border-gray-100 font-normal space-y-3 relative">

                @foreach (var comment in showAllComments
                ? Model.Comments.OrderByDescending(n => n.DateCreated)
                : Model.Comments.OrderByDescending(n => n.DateCreated).Take(2))
                {
                    TimeSpan commentTimeSpanSincePosted = DateTime.UtcNow.Subtract(comment.DateCreated);

                    string commentDisplayTime = commentTimeSpanSincePosted switch
                    {
                        var t when t.TotalDays >= 365 => $"{(int)t.Days / 365}y ago",
                        var t when t.TotalDays >= 60 => $"{(int)t.Days / 30}mos ago",
                        var t when t.TotalDays >= 1 => $"{(int)t.Days}d ago",
                        var t when t.TotalHours >= 1 => $"{(int)t.Hours}h ago",
                        var t when t.TotalMinutes >= 1 => $"{(int)t.Minutes}m ago",
                        _ => "Just now"
                    };

                    <div class="flex items-start gap-3 relative">
                        <a asp-controller="Users" asp-action="Details" asp-route-userId="@comment.UserId">
                            <img src="@(!string.IsNullOrEmpty(comment.User.PfpUrl) ? Url.Content("~/" + comment.User.PfpUrl) : Url.Content(defaultUserPfp))" class="w-6 h-6 mt-1 rounded-full" />
                        </a>
                        <div class="flex-1">
                            <div class="flex justify-content-between">
                                <a asp-controller="Users" asp-action="Details" asp-route-userId="@comment.UserId" class="text-black font-medium inline-block flex-grow">
                                    @comment.User.FullName
                                </a>
                                <small class="text-gray-500">@commentDisplayTime</small>
                            </div>
                            <div class="flex items-center justify-between">
                                <p class="mt-0.5 text-gray-700">
                                    @comment.Content
                                </p>

                                <form asp-controller="Home" asp-action="RemovePostComment" class="remove-comment-form">
                                    @Html.AntiForgeryToken()
                                    <input type="hidden" name="commentId" value="@comment.Id" />
                                    <input type="hidden" name="postId" value="@comment.PostId" />
                                    <button type="submit" class="text-red-500 text-xs ml-2" title="Remove post comment">
                                        <ion-icon name="trash-outline"></ion-icon>
                                    </button>
                                </form>
                            </div>
                        </div>
                    </div>
                }

                @if (Model.Comments.Count >= 3 && !showAllComments)
                {
                    <div class="p-1.5 text-gray-500">
                        <a asp-controller="Home" asp-action="Details" asp-route-postId="@Model.Id">
                            Show all replies
                        </a>
                    </div>
                }

            </div>

            <form asp-controller="Home" asp-action="AddPostComment" class="add-comment-form">
                @Html.AntiForgeryToken()
                <div class="sm:px-4 sm:py-3 p-2.5 border-t border-gray-100 flex items-center gap-1">
                    <a asp-controller="Users" asp-action="Details" asp-route-userId="@loggedInUserId">
                        <img src="@(string.IsNullOrEmpty(currentUserPfp)
                                                     ? Url.Content(defaultUserPfp)
                                                     : Url.Content(currentUserPfp))" class="w-6 h-6 rounded-full" />
                    </a>

                    <input type="hidden" name="postId" value="@Model.Id" />

                    <div class="flex-1 relative overflow-hidden h-10">
                        <textarea name="content"
                                  placeholder="Post your reply"
                                  rows="1"
                                  class="w-full resize-none !bg-transparent px-4 py-2 focus:!border-transparent focus:!ring-transparent !text-black"
                                  id="replyPlaceholder"></textarea>
                    </div>

                    <button type="submit" class="text-sm rounded-full py-1 px-3.5 bg-secondery text-gray-700">Reply</button>
                </div>
            </form>
        </div>
    }

    
</div>
