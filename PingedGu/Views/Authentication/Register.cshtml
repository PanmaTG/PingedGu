@model RegisterViewModel;

@* REGISTER VIEW *@

<div class="sm:flex h-screen overflow-hidden">

    @* Left Side - Image Slider *@
    <div class="flex-1 relative bg-primary max-md:hidden">
        <div class="relative w-full h-full" tabindex="-1" uk-slideshow="animation: slide; autoplay: true">
            <ul class="uk-slideshow-items w-full h-full">
                <li class="w-full">
                    <img src="~/images/slider/pingedgu-slider-3.png" alt="" class="w-full h-full object-cover uk-animation-kenburns uk-animation-reverse uk-transform-origin-center-left " />

                    <div class="absolute bottom-0 w-full uk-transition-slide-bottom-small z-10">
                        <div class="max-w-xl w-full mx-auto pb-32 px-5 z-30 relative">
                            <h4 class="!text-white text-2xl font-semibold mt-7" uk-slideshow-parallax="y:600,0,0">
                                Connect with PingedGus
                            </h4>
                            <p class="!text-white text-lg mt-7 leading-8">Find other PingedGus, connect with them, share and interact with posts together.</p>
                        </div>
                    </div>
                    <div class="w-full h-96 bg-gradient-to-t from-black absolute bottom-0 left-0">
                    </div>
                </li>
                <li class="w-full">
                    <img src="~/images/slider/pingedgu-slider-4.png" alt="" class="w-full h-full object-cover uk-animation-kenburns uk-animation-reverse uk-transform-origin-center-left " />

                    <div class="absolute bottom-0 w-full uk-transition-slide-bottom-small z-10">
                        <div class="max-w-xl w-full mx-auto pb-32 px-5 z-30 relative">
                            <h4 class="!text-white text-2xl font-semibold mt-7" uk-slideshow-parallax="y:600,0,0">
                                Connect with PingedGus
                            </h4>
                            <p class="!text-white text-lg mt-7 leading-8">Noot! Noot!</p>
                        </div>
                    </div>
                    <div class="w-full h-96 bg-gradient-to-t from-black absolute bottom-0 left-0">
                    </div>
                </li>
            </ul>

            <div class="flex justify-center">
                <ul class="inline-flex flex-wrap justify-center absolute bottom-8 gap-1.5 uk-dotnav uk-slideshow-nav">
                </ul>
            </div>

        </div>

    </div>

    @* Right Side - Form for Login *@
    <div class="relative lg:w-[580px] md:w-96 w-full p-10 bg-white shadow-xl flex items-center pt-10 z-10 overflow-y-auto">

        <div class="w-full lg:max-w-sm mx-auto space-y-10">

            <div>
                <h2 class="text-2xl font-semibold mb-1.5">Sign up to PingedGu</h2>
                <p class="text-sm text-gray-700 font-normal">
                    If you already have a PingedGu account
                    <a asp-controller="Authentication" asp-action="Login" class="text-blue-700">Login here!</a>
                </p>
            </div>

            <form asp-controller="Authentication" asp-action="Register" method="post" class="space-y-7 text-sm text-black font-medium">

                <div class="grid grid-cols-2 gap-4 gap-y-7">

                    <div asp-validation-summary="ModelOnly" class="col-span-2 text-red-500"></div>

                    <div>
                        <label asp-for="FirstName">First Name</label>
                        <div class="mt-2.5">
                            <input asp-for="FirstName" id="firstName" name="firstName" type="text" placeholder="First Name" required="" class="!w-full" />

                            <span asp-validation-for="FirstName" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                    <div>
                        <label asp-for="LastName">Last Name</label>
                        <div class="mt-2.5">
                            <input asp-for="LastName" id="lastName" name="lastName" type="text" placeholder="Last Name" required="" class="!w-full" />
                            <span asp-validation-for="LastName" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                    <div class="col-span-2">
                        <label asp-for="Email">Email Address</label>
                        <div class="mt-2.5">
                            <input asp-for="Email" id="email" name="email" type="email" placeholder="Email" required="" class="!w-full" />
                            <span asp-validation-for="Email" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>

                    <div>
                        <label asp-for="Password">Password</label>
                        <div class="mt-2.5">
                            <input asp-for="Password" id="password" name="password" type="password" placeholder="****" required="" class="!w-full" />
                            <span asp-validation-for="Password" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>
                    <div>
                        <label asp-for="ConfirmPassword">Confirm Password</label>
                        <div class="mt-2.5">
                            <input asp-for="ConfirmPassword" id="confirmPassword" name="confirmPassword" type="password" placeholder="****" required="" class="!w-full" />
                            <span asp-validation-for="ConfirmPassword" class="text-red-500 text-xs mt-1"></span>
                        </div>
                    </div>

                    <div class="col-span-2">
                        <button type="submit" class="button bg-primary text-white w-full">Register</button>
                    </div>

                </div>

                <div class="text-center flex items-center gap-6">
                    <hr class="flex-1 border-slate-200" />
                    Or continue with
                    <hr class="flex-1 border-slate-200" />
                </div>

                <div class="flex gap-2">
                    <a asp-controller="Authentication" asp-action="ExternalLogin" asp-route-provider="Google" class="button flex-1 flex items-center gap-2 text-white text-sm" style="background-color: darkorange">
                        <ion-icon name="logo-google" class="text-lg"></ion-icon> Google
                    </a>
                    <a asp-controller="Authentication" asp-action="ExternalLogin" asp-route-provider="GitHub" class="button flex-1 flex items-center gap-2 bg-black text-white text-sm">
                        <ion-icon name="logo-github" class="text-lg"></ion-icon> Github
                    </a>
                </div>
            </form>

        </div>
    </div>
</div>